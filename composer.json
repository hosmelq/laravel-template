{
  "name": "laravel/laravel",
  "description": "The skeleton application for the Laravel framework.",
  "license": "MIT",
  "type": "project",
  "keywords": [
    "laravel",
    "framework"
  ],
  "authors": [
    {
      "name": "Hosmel Quintana",
      "email": "hosmelq@gmail.com"
    }
  ],
  "require": {
    "php": "^8.5",
    "archtechx/enums": "^1.1.2",
    "hosmelq/name-of-person": "^0.3.0",
    "inertiajs/inertia-laravel": "^3.1.1",
    "inertiaui/modal": "^3.1.2",
    "intervention/image": "^4.1.5",
    "laravel/fortify": "^1.37.2",
    "laravel/framework": "^13.19.0",
    "laravel/tinker": "^3.0.2",
    "laravel/wayfinder": "^0.1.20",
    "league/flysystem-aws-s3-v3": "^3.35.2",
    "propaganistas/laravel-disposable-email": "^2.5.0",
    "propaganistas/laravel-phone": "^6.0.3",
    "sentry/sentry-laravel": "^4.26.0",
    "spatie/laravel-health": "^1.40",
    "spatie/laravel-medialibrary": "^11.23.1",
    "spatie/laravel-typescript-transformer": "^3.3.0",
    "thecodingmachine/safe": "^3.4",
    "tpetry/laravel-postgresql-enhanced": "^3.7",
    "tpetry/laravel-query-expressions": "^1.6"
  },
  "require-dev": {
    "driftingly/rector-laravel": "^2.5.0",
    "ergebnis/composer-normalize": "^2.52",
    "fakerphp/faker": "^1.24.1",
    "fruitcake/laravel-debugbar": "^4.4.0",
    "larastan/larastan": "^3.10.0",
    "laravel/boost": "^2.4.11",
    "laravel/pail": "^1.2.7",
    "laravel/pint": "^1.29.3",
    "mockery/mockery": "^1.6.12",
    "nunomaduro/collision": "^8.9.4",
    "pestphp/pest": "^4.7.5",
    "pestphp/pest-plugin-laravel": "^4.1",
    "phpstan/extension-installer": "^1.4.3",
    "phpstan/phpstan-deprecation-rules": "^2.0.4",
    "phpstan/phpstan-strict-rules": "^2.0.11",
    "rector/rector": "^2.5.4",
    "rector/type-perfect": "^2.1.4",
    "shipmonk/composer-dependency-analyser": "^1.8.4",
    "spaze/phpstan-disallowed-calls": "^4.12",
    "thecodingmachine/phpstan-safe-rule": "^1.4.7",
    "ticketswap/phpstan-error-formatter": "^1.3.0",
    "tomasvotruba/type-coverage": "^2.2.2"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    },
    "files": [
      "app/functions.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "ergebnis/composer-normalize": true,
      "pestphp/pest-plugin": true,
      "php-http/discovery": true,
      "phpstan/extension-installer": true
    },
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "scripts": {
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
      "@composer bump",
      "@composer normalize",
      "@php artisan boost:install --ansi --guidelines --mcp --skills --no-interaction"
    ],
    "pre-package-uninstall": [
      "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
    ],
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "agent:setup": [
      "@php artisan boost:install --ansi --guidelines --mcp --skills --no-interaction",
      "nubx skills experimental_install"
    ],
    "fresh": "@php artisan migrate:fresh --seed",
    "phpstan": "phpstan analyse --memory-limit=4G",
    "pint": "pint",
    "rector": "rector",
    "setup": [
      "composer install",
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
      "@php -r \"file_exists('.env.testing') || copy('.env.testing.example', '.env.testing');\"",
      "@php artisan key:generate",
      "@php artisan key:generate --env=testing",
      "@php artisan migrate --force",
      "nub install --frozen-lockfile",
      "nub run build"
    ],
    "test": "@php artisan test",
    "typescript": "@php artisan typescript:transform --no-interaction",
    "wayfinder": "@php artisan wayfinder:generate --skip-routes"
  },
  "scripts-descriptions": {
    "agent:setup": "Runs project agent setup.",
    "fresh": "Runs migrate:fresh and db:seed.",
    "phpstan": "Runs PHPStan analyse.",
    "pint": "Runs Pint.",
    "rector": "Runs Rector.",
    "setup": "Installs dependencies, prepares environment files and keys, runs migrations, and builds frontend assets.",
    "test": "Runs the application tests.",
    "typescript": "Generates TypeScript definitions from PHP types.",
    "wayfinder": "Generates TypeScript definitions for routes and controller methods."
  },
  "$schema": "https://getcomposer.org/schema.json"
}
