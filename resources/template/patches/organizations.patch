diff -ruN -U0 a/tests/Integration/Models/UserTest.php b/tests/Integration/Models/UserTest.php
--- a/tests/Integration/Models/UserTest.php	1969-12-31 18:00:00
+++ b/tests/Integration/Models/UserTest.php	2026-07-23 05:58:35
@@ -0,0 +1,59 @@
+<?php
+
+declare(strict_types=1);
+
+use App\Models\Organization;
+use App\Models\User;
+
+it('checks is a user belongs to an organization', function (): void {
+    $organization = Organization::factory()->createOne();
+    $user = User::factory()->createOne();
+
+    expect($user->belongsToOrganization($organization))->toBeFalse();
+
+    $organization->users()->attach($user);
+
+    $user->refresh();
+
+    expect($user->belongsToOrganization($organization))->toBeTrue();
+});
+
+it('checks is a user owns an organization', function (): void {
+    $user = User::factory()->createOne();
+    $userOrganization = Organization::factory()->for($user, 'owner')->createOne();
+    $unrelatedOrganization = Organization::factory()->createOne();
+
+    expect($user->ownsOrganization($userOrganization))->toBeTrue()
+        ->and($user->ownsOrganization($unrelatedOrganization))->toBeFalse();
+});
+
+it('sets current_organization_id when loading currentOrganization if it not already set', function (): void {
+    $user = User::factory()
+        ->has(Organization::factory(), 'organizations')
+        ->createOne();
+
+    expect($user->current_organization_id)->toBeNull();
+
+    $user->currentOrganization;
+
+    expect($user->fresh()->current_organization_id)->not->toBeNull();
+});
+
+it('cannot switch to an unrelated organization', function (): void {
+    $unrelatedOrganization = Organization::factory()->createOne();
+
+    $user = User::factory()->createOne();
+
+    expect($user)
+        ->switchOrganization($unrelatedOrganization)->toBeFalse()
+        ->currentOrganization->toBeNull();
+});
+
+it('can switch to a related organization', function (): void {
+    $organization = Organization::factory()->createOne();
+    $user = User::factory()->withOrganization($organization)->createOne();
+
+    expect($user)
+        ->switchOrganization($organization)->toBeTrue()
+        ->currentOrganization->is($organization)->toBeTrue();
+});
