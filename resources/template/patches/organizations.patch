+ * @property-read Collection<int, Organization> $organizations
+ * @property-read Collection<int, Organization> $ownedOrganizations
@@ -36,0 +45,77 @@
+
+    public function belongsToOrganization(null|Organization $organization): bool
+    {
+        if (! $organization instanceof Organization) {
+            return false;
+        }
+
+        if ($this->ownsOrganization($organization)) {
+            return true;
+        }
+
+        return $this->organizations->contains($organization);
+    }
+
+    /**
+     * @return BelongsTo<Organization, $this>
+     */
+    public function currentOrganization(): BelongsTo
+    {
+        if ($this->current_organization_id === null && ($organization = $this->organizations->first()) !== null) {
+            $this->switchOrganization($organization);
+        }
+
+        return $this->belongsTo(Organization::class, 'current_organization_id');
+    }
+
+    public function isCurrentOrganization(Organization $organization): bool
+    {
+        if ($this->currentOrganization === null) {
+            return false;
+        }
+
+        return $this->currentOrganization->id === $organization->id;
+    }
+
+    /**
+     * @return BelongsToMany<Organization, $this, Membership, 'membership'>
+     */
+    public function organizations(): BelongsToMany
+    {
+        return $this->belongsToMany(Organization::class)
+            ->as('membership')
+            ->using(Membership::class)
+            ->withTimestamps();
+    }
+
+    /**
+     * @return HasMany<Organization, $this>
+     */
+    public function ownedOrganizations(): HasMany
+    {
+        return $this->hasMany(Organization::class, 'owner_id');
+    }
+
+    public function ownsOrganization(null|Organization $organization): bool
+    {
+        if (! $organization instanceof Organization) {
+            return false;
+        }
+
+        return $this->id === $organization->owner_id;
+    }
+
+    public function switchOrganization(Organization $organization): bool
+    {
+        if (! $this->belongsToOrganization($organization)) {
+            return false;
+        }
+
+        $this->update([
+            'current_organization_id' => $organization->id,
+        ]);
+
+        $this->setRelation('currentOrganization', $organization);
+
+        return true;
+    }
