+it('generates a slug when creating an organization', function (): void {
+    $organization = Organization::factory()->createOne([
+        'name' => 'My Organization',
+    ]);
+
+    expect($organization->slug)->toBe('my-organization');
+});
+
+it('does not regenerate the slug when the organization name changes', function (): void {
+    $organization = Organization::factory()->createOne([
+        'name' => 'My Organization',
+    ]);
+
+    $organization->update([
+        'name' => 'Updated Organization',
+    ]);
+
+    expect($organization->refresh()->slug)->toBe('my-organization');
