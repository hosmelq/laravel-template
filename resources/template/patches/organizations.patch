+++ b/app/Actions/Organizations/CreateOrganization.php	2026-07-23 05:58:35
@@ -0,0 +1,26 @@
+<?php
+
+declare(strict_types=1);
+
+namespace App\Actions\Organizations;
+
+use App\Actions\Organizations\Inputs\CreateOrganizationInput;
+use App\Models\Organization;
+use App\Models\User;
+use Illuminate\Support\Facades\DB;
+
+class CreateOrganization
+{
+    public function handle(User $user, CreateOrganizationInput $input): Organization
+    {
+        return DB::transaction(function () use ($user, $input): Organization {
+            $organization = $user->ownedOrganizations()->create($input->transform());
+
+            $organization->users()->attach($user);
+
+            $user->switchOrganization($organization);
+
+            return $organization;
+        });
+    }
+}
