{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "options": {
    "reportUnusedDisableDirectives": "error",
    "typeAware": true,
    "typeCheck": true
  },
  "plugins": ["eslint", "import", "jsx-a11y", "oxc", "promise", "react", "typescript", "unicorn"],
  "rules": {
    "import/no-cycle": "error"
  }
}
