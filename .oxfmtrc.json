{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "bracketSpacing": false,
  "ignorePatterns": [
    "AGENTS.md",
    "boost.json",
    "opencode.json",
    "resources/react-email/.react-email",
    "storage",
    "tests/.pest/shards.json"
  ],
  "semi": false,
  "singleQuote": true,
  "sortImports": {
    "groups": [
      ["builtin"],
      ["external"],
      ["internal"],
      ["parent", "sibling", "index"],
      ["unknown"]
    ],
    "internalPattern": ["#/"]
  },
  "sortPackageJson": {
    "sortScripts": true
  },
  "sortTailwindcss": {
    "functions": ["cn"],
    "stylesheet": "./resources/js/index.css"
  }
}
