{
  "name": "template",
  "packageManager": "pnpm@10.11.1",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "fix": "oxlint --fix --fix-dangerously --fix-suggestions",
    "format": "prettier --write \"**/*.{cjs,css,js,json,jsx,md,mjs,ts,tsx}\"",
    "lint": "oxlint",
    "prepare": "husky",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.4.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "oxlint": "^1.5.0",
    "prettier": "^3.6.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.34.1",
    "vite": "^7.0.0"
  }
}
